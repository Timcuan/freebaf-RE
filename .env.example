# freebaf-RE — gateway config (local / VPS)
# Copy to `.env` and fill in. Lines starting with # are comments.

# ── Required ─────────────────────────────────────────────────────────
# Get a token at https://freebuff.071129.xyz/ then paste it below.
FREEBUFF_TOKEN=

# Your API key for /v1/* (clients send `Authorization: Bearer <this>`)
FREEBUFF_API_KEY=

# Admin panel password for /admin (CHANGE FROM DEFAULT for public deploy)
FREEBUFF_ADMIN_KEY=sk-admin

# ── Deployment Mode ──────────────────────────────────────────────────
# Auto-detected: local | vps | vercel | cloudrun | lambda
# Override if needed:
# FREEBUFF_DEPLOY_MODE=local

# Host/port (local + VPS only; Vercel ignores)
FREEBUFF_HOST=0.0.0.0
FREEBUFF_PORT=8000

# ── Egress Region Control (KEY FOR NON-US DEPLOYMENTS) ──────────────
# Codebuff free-tier requires US/EU egress IP.
# Non-US IPs get 409 `session_model_mismatch` from upstream.
#
# Auto-detect region on startup + warn if non-premium (default: true)
FREEBUFF_EGRESS_AUTO=true

# Required region (uppercase ISO code). If set + not satisfied, logs error.
# FREEBUFF_EGRESS_REGION=US

# Egress proxy — routes ALL upstream requests through this.
# Supports SOCKS5/HTTP/HTTPS via httpx[socks].
# Examples:
#   FREEBUFF_EGRESS_PROXY_URL=socks5://user:pass@proxy.example.com:1080
#   FREEBUFF_EGRESS_PROXY_URL=socks5h://proxy.example.com:1080  (DNS via proxy)
#   FREEBUFF_EGRESS_PROXY_URL=http://proxy.example.com:8080
FREEBUFF_EGRESS_PROXY_URL=

# Legacy proxy support (same as above, kept for backward compat)
FREEBUFF_PROXY_ENABLED=false
FREEBUFF_PROXY_URL=

# ── Upstream ─────────────────────────────────────────────────────────
FREEBUFF_API_BASE_URL=https://www.codebuff.com
ZEROCLICK_BASE_URL=https://zeroclick.dev
FREEBUFF_AD_PROVIDERS=gravity,zeroclick
FREEBUFF_TIMEOUT=60

# ── Stealth: upstream client fingerprint ─────────────────────────────
# Defaults match the latest verified Codebuff CLI release (codebuff@1.0.682,
# June 2026). Override only to track upstream version bumps.
FREEBUFF_CLI_USER_AGENT=codebuff/1.0.682
FREEBUFF_FREEBUFF_CLI_USER_AGENT=Freebuff-CLI/0.0.105
# Per-account fingerprints are persisted to ~/.config/freebaf-re/fingerprints.json
# (override with FREEBUFF_FINGERPRINT_STORE). Each account gets a stable
# codebuff-cli-<8 base64url> fingerprint — matches the official CLI legacy
# fallback format so accounts are not flagged as non-official clients.
# FREEBUFF_FINGERPRINT_STORE=
# TLS fingerprint mimicry via curl_cffi (impersonates Chrome's JA3/JA4).
# Disable only if curl_cffi causes issues upstream.
# FREEBUFF_STEALTH_TLS=true

# ── Per-account identity isolation (anti cross-account correlation) ──
# When running multiple accounts, upstream bot-sweep clusters accounts by
# shared IP, TLS fingerprint, User-Agent, and timing. Identity isolation
# assigns each account a distinct bundle so accounts don't correlate.
# Master switch (default: true). Set false to use global settings for all.
# FREEBUFF_IDENTITY_ISOLATION=true
# Per-account proxies (comma-separated, one per account). STRONGLY recommended
# for multi-account stealth — distinct residential IPs are the strongest
# isolation signal. Accounts beyond the list fall back to FREEBUFF_EGRESS_PROXY_URL.
# FREEBUFF_PER_ACCOUNT_PROXY=socks5://u:p@host1:1080,socks5://u:p@host2:1080,...
# Per-account TLS profile (curl_cffi browser profiles). Defaults to rotating
# through: chrome124, chrome120, chrome116, chrome110, edge99, safari17_0, ...
# FREEBUFF_PER_ACCOUNT_TLS=chrome124,chrome120,safari17_0
# Per-account CLI version (User-Agent = codebuff/<version>). Defaults to
# rotating through recent real releases.
# FREEBUFF_PER_ACCOUNT_CLI_VERSION=1.0.682,1.0.680,1.0.681
# Per-account locale (Accept-Language + device locale). Distinct locales
# break the "all accounts same region" signal.
# FREEBUFF_PER_ACCOUNT_LOCALE=en-US,zh-CN,en-GB,ja-JP
# Per-account device timezone.
# FREEBUFF_PER_ACCOUNT_TIMEZONE=America/New_York,Asia/Shanghai,Europe/London
# Activity phase stagger (minutes) — distributes account activity across
# the hour so accounts don't all peak at the same minute.
# FREEBUFF_ACCOUNT_STAGGER_MINUTES=15

# ── System prompt override ───────────────────────────────────────────
# Inject custom system prompt (replaces default "You are Buffy..." upstream prompt).
# - unset/None: use default Buffy-neutralizer prefix (recommended for chat UIs)
# - empty string: pure passthrough — do NOT inject any prefix (recommended for
#   agent integration: Cursor, Hermes, Claude Code, etc. — your system prompt
#   passes through untouched)
# - non-empty: prepend this string to the user's system prompt
# FREEBUFF_SYSTEM_PROMPT_OVERRIDE=

# ── Multi API Key (advanced) ─────────────────────────────────────────
# JSON array; each key can have its own allowed_models whitelist:
# FREEBUFF_API_KEYS=[{"name":"default","key":"sk-xxx","allowed_models":["*"],"enabled":true}]

# ── Logging ──────────────────────────────────────────────────────────
FREEBUFF_DEBUG=false
FREEBUFF_LOG_LEVEL=INFO
FREEBUFF_LOG_BODY_CHARS=2000
FREEBUFF_LOG_COLOR=true
FREEBUFF_ADMIN_LOG_LINES=1000

# ── Upstream fingerprint (mirror official Codebuff CLI defaults) ─────
# These must match the upstream client fingerprint to avoid detection.
# Override only if you know the exact fingerprint expected by the current
# Codebuff release.
FREEBUFF_TIMEZONE=Asia/Shanghai
FREEBUFF_LOCALE=zh-CN
FREEBUFF_OS=windows

# ── Usage records (in-memory; persist to disk in local/VPS) ─────────
FREEBUFF_MAX_REQUEST_RECORDS=5000

# ── Freebuff Unleash (unlimited via Codebuff loopholes) ──────────────
# Multi-account × multi-model session pool.
# N accounts × 5 models = 5N cached sessions, 24/7 access via session persistence.
# Background warmup pre-emptively refreshes every 55min (race-free).
# Fallback chain: GLM → Kimi → DeepSeek → MiniMax.
# No additional config — uses FREEBUFF_TOKEN above.
# More accounts = more concurrent throughput (N × unlimited in-session).

# ── Rate Governor (anti 24/7 bot-sweep) ──────────────────────────────
# Idle window opt-in. Default: DISABLED (gateway always usable).
# Format: "start_hour,end_hour" in 24h local time (wraps midnight).
# Examples:
#   FREEBUFF_IDLE_WINDOW_HOURS=0,7     # sleep 00:00-07:00 (no requests)
#   FREEBUFF_IDLE_WINDOW_HOURS=22,7    # sleep 22:00-07:00 (wraps midnight)
#   FREEBUFF_IDLE_WINDOW_HOURS=        # disabled (default)
# FREEBUFF_IDLE_WINDOW_HOURS=

# Local timezone offset (hours from UTC) for idle window calculation.
# Default 0 (UTC). Set to 7 for WIB, 8 for WITA, etc.
# FREEBUFF_LOCAL_OFFSET_HOURS=0
